"""
DAG: gold_extended_pipeline
Build extended Gold Iceberg analytics tables from Gold MVP tables.
"""

from datetime import datetime, timedelta

from airflow.decorators import dag
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator


_J = "/opt/project/jars"
_JARS = [
    f"{_J}/org.apache.hadoop_hadoop-aws-3.4.2.jar",
    f"{_J}/org.apache.hadoop_hadoop-client-api-3.4.2.jar",
    f"{_J}/org.apache.hadoop_hadoop-client-runtime-3.4.2.jar",
    f"{_J}/software.amazon.awssdk_bundle-2.29.52.jar",
    f"{_J}/org.apache.spark_spark-sql-kafka-0-10_2.13-4.1.1.jar",
    f"{_J}/org.apache.spark_spark-token-provider-kafka-0-10_2.13-4.1.1.jar",
    f"{_J}/org.apache.kafka_kafka-clients-3.9.1.jar",
    f"{_J}/org.apache.commons_commons-pool2-2.12.1.jar",
    f"{_J}/org.lz4_lz4-java-1.8.0.jar",
    f"{_J}/org.xerial.snappy_snappy-java-1.1.10.8.jar",
    f"{_J}/org.slf4j_slf4j-api-2.0.17.jar",
    f"{_J}/org.scala-lang.modules_scala-parallel-collections_2.13-1.2.0.jar",
    f"{_J}/iceberg-spark-runtime-4.0_2.13-1.10.1.jar",
    f"{_J}/postgresql-42.7.4.jar",
]
CLASSPATH = ":".join(_JARS)


default_args = {
    "owner": "agent4da",
    "retries": 1,
    "retry_delay": timedelta(minutes=3),
    "depends_on_past": False,
    "email_on_failure": False,
    "email_on_retry": False,
}


@dag(
    dag_id="gold_extended_pipeline",
    description="Build extended Gold Iceberg analytics tables from Gold MVP tables",
    default_args=default_args,
    start_date=datetime(2026, 5, 1),
    schedule=None,
    catchup=False,
    max_active_runs=1,
    is_paused_upon_creation=False,
    tags=["gold", "iceberg", "extended", "etl"],
)
def gold_extended_pipeline():
    SparkSubmitOperator(
        task_id="gold_extended_job",
        conn_id="spark_default",
        application="/opt/project/code/spark/gold_extended_job.py",
        jars=None,
        driver_class_path=CLASSPATH,
        conf={
            "spark.executor.extraClassPath": CLASSPATH,
            "spark.pyspark.python": "/usr/bin/python3",
            "spark.pyspark.driver.python": "/usr/bin/python3",
            "spark.executorEnv.PYSPARK_PYTHON": "/usr/bin/python3",
            "spark.sql.extensions": "org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions",
            "spark.sql.catalog.iceberg_catalog": "org.apache.iceberg.spark.SparkCatalog",
            "spark.sql.catalog.iceberg_catalog.catalog-impl": "org.apache.iceberg.jdbc.JdbcCatalog",
            "spark.sql.catalog.iceberg_catalog.uri": "jdbc:postgresql://postgres-db:5432/agent4da",
            "spark.sql.catalog.iceberg_catalog.jdbc.user": "bigdata",
            "spark.sql.catalog.iceberg_catalog.jdbc.password": "change_me",
            "spark.sql.catalog.iceberg_catalog.jdbc.currentSchema": "iceberg",
            "spark.sql.catalog.iceberg_catalog.warehouse": "s3a://gold/warehouse/",
            "spark.sql.catalog.iceberg_catalog.io-impl": "org.apache.iceberg.hadoop.HadoopFileIO",
            "spark.hadoop.fs.s3a.endpoint": "http://minio:9000",
            "spark.hadoop.fs.s3a.access.key": "admin",
            "spark.hadoop.fs.s3a.secret.key": "change_me",
            "spark.hadoop.fs.s3a.path.style.access": "true",
            "spark.hadoop.fs.s3a.impl": "org.apache.hadoop.fs.s3a.S3AFileSystem",
            "spark.hadoop.fs.s3a.aws.credentials.provider": "org.apache.hadoop.fs.s3a.SimpleAWSCredentialsProvider",
            "spark.hadoop.fs.s3a.connection.ssl.enabled": "false",
            "spark.sql.shuffle.partitions": "4",
            "spark.driver.extraJavaOptions": "-Dorg.slf4j.simpleLogger.defaultLogLevel=WARN",
            "spark.executor.extraJavaOptions": "-Dorg.slf4j.simpleLogger.defaultLogLevel=WARN",
            "spark.executorEnv.MINIO_ENDPOINT": "http://minio:9000",
            "spark.executorEnv.MINIO_ACCESS_KEY": "admin",
            "spark.executorEnv.MINIO_SECRET_KEY": "change_me",
            "spark.executorEnv.ICEBERG_CATALOG_NAME": "iceberg_catalog",
            "spark.executorEnv.ICEBERG_NAMESPACE": "gold",
            "spark.executorEnv.ICEBERG_WAREHOUSE": "s3a://gold/warehouse/",
            "spark.executorEnv.ICEBERG_JDBC_URI": "jdbc:postgresql://postgres-db:5432/agent4da",
            "spark.executorEnv.ICEBERG_JDBC_USER": "bigdata",
            "spark.executorEnv.ICEBERG_JDBC_PASSWORD": "change_me",
            "spark.executorEnv.ICEBERG_JDBC_SCHEMA": "iceberg",
            "spark.executorEnv.GOLD_EXTENDED_WRITE_MODE": "overwrite_partitions",
            "spark.executorEnv.GOLD_EXTENDED_DRY_RUN": "false",
            "spark.executorEnv.GOLD_EXTENDED_VALIDATE_TABLES": "true",
            "spark.executorEnv.RESET_EXTENDED_DIMENSIONS": "false",
        },
        packages=None,
        name="GoldExtendedJob",
        verbose=True,
        execution_timeout=timedelta(minutes=20),
    )


gold_extended_pipeline()
